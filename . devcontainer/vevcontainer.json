{
  "name": "Project Aura Dev",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "nvidiv.usd-vscode"]
    }
  },
  "postCreateCommand": "pip install -r requirements.txt"
}
{
    "name": "Project Aura: Robotics Dev",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {},
        "ghcr.io/devcontainers/features/git:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-iot.vscode-ros",
                "nvidia.isaac-sim-vscode"
            ]
        }
    },
    "remoteUser": "vscode",
    "postCreateCommand": "sudo apt update && sudo apt install -y python3-pip && pip install -r requirements.txt"
}
