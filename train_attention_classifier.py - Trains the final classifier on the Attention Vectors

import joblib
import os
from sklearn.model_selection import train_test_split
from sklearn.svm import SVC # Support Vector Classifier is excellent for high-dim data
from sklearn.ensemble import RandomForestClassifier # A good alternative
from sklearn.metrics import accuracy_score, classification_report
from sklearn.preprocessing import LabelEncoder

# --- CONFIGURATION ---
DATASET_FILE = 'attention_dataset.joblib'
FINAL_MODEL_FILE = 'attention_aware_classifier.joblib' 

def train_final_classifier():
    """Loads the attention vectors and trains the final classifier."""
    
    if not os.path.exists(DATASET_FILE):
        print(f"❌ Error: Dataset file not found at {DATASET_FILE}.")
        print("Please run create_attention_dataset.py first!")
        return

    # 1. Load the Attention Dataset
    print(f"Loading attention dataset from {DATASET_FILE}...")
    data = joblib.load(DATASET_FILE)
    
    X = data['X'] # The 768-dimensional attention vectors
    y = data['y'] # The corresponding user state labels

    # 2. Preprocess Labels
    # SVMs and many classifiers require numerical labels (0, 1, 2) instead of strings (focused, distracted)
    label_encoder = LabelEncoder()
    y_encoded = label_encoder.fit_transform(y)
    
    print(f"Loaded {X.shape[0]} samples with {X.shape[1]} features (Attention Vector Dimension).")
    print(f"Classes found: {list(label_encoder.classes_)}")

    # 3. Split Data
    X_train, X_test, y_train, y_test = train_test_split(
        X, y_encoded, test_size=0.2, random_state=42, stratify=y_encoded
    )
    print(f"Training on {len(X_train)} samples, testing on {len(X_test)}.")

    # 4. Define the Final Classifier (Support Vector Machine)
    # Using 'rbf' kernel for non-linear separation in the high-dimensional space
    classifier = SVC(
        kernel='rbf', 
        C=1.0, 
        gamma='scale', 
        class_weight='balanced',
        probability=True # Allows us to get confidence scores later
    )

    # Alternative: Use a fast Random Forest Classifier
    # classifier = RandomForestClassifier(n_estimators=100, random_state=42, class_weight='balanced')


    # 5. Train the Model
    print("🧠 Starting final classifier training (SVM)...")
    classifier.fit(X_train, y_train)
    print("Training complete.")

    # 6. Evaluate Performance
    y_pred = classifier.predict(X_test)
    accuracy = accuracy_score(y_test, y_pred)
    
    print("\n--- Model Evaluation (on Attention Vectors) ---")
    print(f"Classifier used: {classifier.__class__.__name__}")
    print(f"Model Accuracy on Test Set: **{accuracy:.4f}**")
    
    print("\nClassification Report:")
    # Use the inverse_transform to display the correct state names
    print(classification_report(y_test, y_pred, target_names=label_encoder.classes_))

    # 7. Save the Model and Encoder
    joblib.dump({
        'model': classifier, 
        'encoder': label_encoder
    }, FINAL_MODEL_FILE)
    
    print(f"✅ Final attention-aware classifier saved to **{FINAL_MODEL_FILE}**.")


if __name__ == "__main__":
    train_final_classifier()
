# train_attention_classifier.py - Trains the final classifier on the Attention Vectors

import joblib
import os
from sklearn.model_selection import train_test_split
from sklearn.svm import SVC # Support Vector Classifier is excellent for high-dim data
from sklearn.ensemble import RandomForestClassifier # A good alternative
from sklearn.metrics import accuracy_score, classification_report
from sklearn.preprocessing import LabelEncoder

# --- CONFIGURATION ---
DATASET_FILE = 'attention_dataset.joblib'
FINAL_MODEL_FILE = 'attention_aware_classifier.joblib' 

def train_final_classifier():
    """Loads the attention vectors and trains the final classifier."""
    
    if not os.path.exists(DATASET_FILE):
        print(f"❌ Error: Dataset file not found at {DATASET_FILE}.")
        print("Please run create_attention_dataset.py first!")
        return

    # 1. Load the Attention Dataset
    print(f"Loading attention dataset from {DATASET_FILE}...")
    data = joblib.load(DATASET_FILE)
    
    X = data['X'] # The 768-dimensional attention vectors
    y = data['y'] # The corresponding user state labels

    # 2. Preprocess Labels
    # SVMs and many classifiers require numerical labels (0, 1, 2) instead of strings (focused, distracted)
    label_encoder = LabelEncoder()
    y_encoded = label_encoder.fit_transform(y)
    
    print(f"Loaded {X.shape[0]} samples with {X.shape[1]} features (Attention Vector Dimension).")
    print(f"Classes found: {list(label_encoder.classes_)}")

    # 3. Split Data
    X_train, X_test, y_train, y_test = train_test_split(
        X, y_encoded, test_size=0.2, random_state=42, stratify=y_encoded
    )
    print(f"Training on {len(X_train)} samples, testing on {len(X_test)}.")

    # 4. Define the Final Classifier (Support Vector Machine)
    # Using 'rbf' kernel for non-linear separation in the high-dimensional space
    classifier = SVC(
        kernel='rbf', 
        C=1.0, 
        gamma='scale', 
        class_weight='balanced',
        probability=True # Allows us to get confidence scores later
    )

    # Alternative: Use a fast Random Forest Classifier
    # classifier = RandomForestClassifier(n_estimators=100, random_state=42, class_weight='balanced')


    # 5. Train the Model
    print("🧠 Starting final classifier training (SVM)...")
    classifier.fit(X_train, y_train)
    print("Training complete.")

    # 6. Evaluate Performance
    y_pred = classifier.predict(X_test)
    accuracy = accuracy_score(y_test, y_pred)
    
    print("\n--- Model Evaluation (on Attention Vectors) ---")
    print(f"Classifier used: {classifier.__class__.__name__}")
    print(f"Model Accuracy on Test Set: **{accuracy:.4f}**")
    
    print("\nClassification Report:")
    # Use the inverse_transform to display the correct state names
    print(classification_report(y_test, y_pred, target_names=label_encoder.classes_))

    # 7. Save the Model and Encoder
    joblib.dump({
        'model': classifier, 
        'encoder': label_encoder
    }, FINAL_MODEL_FILE)
    
    print(f"✅ Final attention-aware classifier saved to **{FINAL_MODEL_FILE}**.")


if __name__ == "__main__":
    train_final_classifier()
