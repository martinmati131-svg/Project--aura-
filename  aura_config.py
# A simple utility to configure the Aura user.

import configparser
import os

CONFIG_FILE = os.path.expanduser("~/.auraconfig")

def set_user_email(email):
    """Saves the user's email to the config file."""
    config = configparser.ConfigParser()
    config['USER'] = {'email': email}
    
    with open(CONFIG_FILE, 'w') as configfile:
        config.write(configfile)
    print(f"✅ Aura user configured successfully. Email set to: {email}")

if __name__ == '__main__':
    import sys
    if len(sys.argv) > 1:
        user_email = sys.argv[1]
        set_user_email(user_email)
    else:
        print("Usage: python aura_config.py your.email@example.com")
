# aura_config.py
# A simple utility to configure the Aura user.

import configparser
import os

CONFIG_FILE = os.path.expanduser("~/.auraconfig")

def set_user_email(email):
    """Saves the user's email to the config file."""
    config = configparser.ConfigParser()
    config['USER'] = {'email': email}
    
    with open(CONFIG_FILE, 'w') as configfile:
        config.write(configfile)
    print(f"✅ Aura user configured successfully. Email set to: {email}")

if __name__ == '__main__':
    import sys
    if len(sys.argv) > 1:
        user_email = sys.argv[1]
        set_user_email(user_email)
    else:
        print("Usage: python aura_config.py your.email@example.com")
