from pxr import Usd, UsdLux, UsdGeom

# 1. Open your existing stage
stage = Usd.Stage.Open("_assets/prims.usda")

# 2. Get the Session Layer (this is always created for you)
session_layer = stage.GetSessionLayer()

# 3. Target the Session Layer for edits
stage.SetEditTarget(Usd.EditTarget(session_layer))

# 4. Create a temporary "Aura Basic" light
# This light will exist as long as the 'stage' object is in memory
temp_light = UsdLux.SphereLight.Define(stage, "/temp_work_light")
temp_light.CreateIntensityAttr().Set(2000)
temp_light.CreateColorAttr().Set((1, 0.9, 0.7))

# 5. Save the STAGE
stage.Save() 
# result: 'prims.usda' is saved, BUT 'temp_work_light' IS NOT IN THE FILE.
# If you have a light in your Root layer, you can "mute" it 
# by authoring a 0 intensity override in the Session Layer.
stage.SetEditTarget(stage.GetSessionLayer())

# Overriding an existing light at /World/SunLight
sun_override = UsdLux.DistantLight.Get(stage, "/World/SunLight")
if sun_override:
    sun_override.CreateIntensityAttr().Set(0) # Temporarily "turn off" the sun
