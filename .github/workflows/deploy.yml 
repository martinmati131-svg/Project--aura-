name: Aura Platform Deployer

on:
  push:
    branches: [ main ]

jobs:
  test-and-deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v3

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.9'

      - name: Install Dependencies
        run: pip install requests

      - name: Run Weather API Test
        run: python test_weather.py

      - name: Validate Dashboard HTML
        run: |
          [ -s index.html ] || exit 1 

      - name: Deploy to GitHub Pages
        if: success() # Only deploys if all previous steps (tests) passed
        uses: JamesIves/github-pages-deploy-action@v4
        with:
          folder: .
          branch: gh-pages
