# app_watcher.py
# Project Aura: v0.2
# This script now detects and reports context switches between applications.

import time
from AppKit import NSWorkspace

def get_active_app_name():
    """
    Uses the AppKit framework to get the name of the frontmost application.
    """
    try:
        active_app = NSWorkspace.sharedWorkspace().frontmostApplication()
        app_name = active_app.localizedName()
        return app_name
    except Exception as e:
        return f"Unknown ({e})"

if __name__ == "__main__":
    print("Starting Context Switch Detector... Press CTRL+C to stop.")
    previous_app = None # Variable to store the last known application
    
    try:
        while True:
            current_app = get_active_app_name()
            
            # Check if the application has changed
            if current_app != previous_app:
                timestamp = time.strftime('%H:%M:%S')
                
                # We log the switch, ignoring the very first run
                if previous_app is not None:
                    print(f"[{timestamp}] CONTEXT SWITCH: From '{previous_app}' to '{current_app}'")
                
                # Update the previous_app to the current one
                previous_app = current_app
            
            time.sleep(2)
            
    except KeyboardInterrupt:
        print("\nStopping detector. Goodbye!")
